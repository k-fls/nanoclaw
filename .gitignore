# Dependencies
node_modules/
.npm-cache/
# Build output
dist/
cascade/dist/

# Cascade derived artifacts (regenerated by `cascade ownership` / `cascade check`)
/.ownership_map.txt
/.edition-snapshot.json
# Cascade per-intake working state (triage plans, inspector verdicts).
# Dot-prefixed subdir signals ephemeral tool state; not source.
/.cascade/.intake/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md

# Secrets
*.keys.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
coverage/