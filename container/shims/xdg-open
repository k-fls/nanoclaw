#!/bin/sh
# Shim replacing xdg-open inside containers.
# Calls the credential proxy to check if the URL is a known OAuth endpoint.
# Known OAuth URLs are relayed to the user via the messaging channel.
# Unknown URLs: try the real xdg-open if it exists, otherwise fail (no browser).
RESULT=$(curl -sf -X POST \
  "http://$PROXY_HOST:$PROXY_PORT/auth/browser-open" \
  -H "Content-Type: application/json" \
  -d "{\"url\":\"$1\"}")
EXIT_CODE=$(echo "$RESULT" | sed -n 's/.*"exit_code":\([0-9]*\).*/\1/p')
if [ -n "$EXIT_CODE" ]; then
  exit "$EXIT_CODE"
fi
# Pass-through: not a known OAuth URL. Try the real binary if the image has one.
[ -x /usr/bin/xdg-open.real ] && exec /usr/bin/xdg-open.real "$1"
exit 1
