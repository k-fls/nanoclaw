#!/bin/sh
# Shim replacing xdg-open inside auth containers.
# Captures the OAuth URL for the auth flow.
# If the URL has a localhost callback port, waits until it's listening
# before writing — so the host knows the port is ready for delivery.
# Exits 0 so the CLI thinks the browser opened and waits for the callback.

URL="$1"
PORT=$(echo "$URL" | grep -oP 'redirect_uri=http%3A%2F%2Flocalhost%3A\K\d+' || true)

if [ -n "$PORT" ]; then
  # Wait up to 5s for the CLI to open its callback listener
  for i in $(seq 1 50); do
    if nc -z 127.0.0.1 "$PORT" 2>/dev/null; then
      break
    fi
    sleep 0.1
  done
fi

echo "$URL" > /workspace/auth-ipc/.oauth-url
exit 0
