{
  "issuer": "https://www.figma.com",
  "authorization_endpoint": "https://www.figma.com/oauth",
  "token_endpoint": "https://api.figma.com/v1/oauth/token",
  "userinfo_endpoint": "https://api.figma.com/v1/oauth/userinfo",
